# This file is automatically generated by Cookiecutter.

# Define the stages of the pipeline
stages:
  - quality
  - test
  - publish

variables:
  UV_VERSION: "0.8"
  PYTHON_VERSION: "{{ cookiecutter.python_version }}"
  BASE_LAYER: bookworm-slim
  # GitLab CI creates a separate mountpoint for the build directory,
  # so we need to copy instead of using hard links.
  UV_LINK_MODE: copy
  UV_PUBLISH_URL: "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/pypi"
  UV_PUBLISH_USERNAME: "gitlab-ci-token"
  UV_PUBLISH_PASSWORD: "${CI_JOB_TOKEN}"

# Define a reusable base job configuration
.base_py_job:
  image: ghcr.io/astral-sh/uv:$UV_VERSION-python$PYTHON_VERSION-$BASE_LAYER
  rules:
    - changes:
        - src/**/*
        - tests/*
        - pyproject.toml
        - uv.lock
  before_script:
    - uv sync --group dev

# --- Job Definitions ---

format-check:
  extends: .base_py_job
  stage: quality
  script:
    - echo "Checking formatting with Ruff..."
    - uv run ruff format --check .

lint:
  extends: .base_py_job
  stage: quality
  script:
    - echo "Linting with Ruff..."
    - uv run ruff check .

docstrings:
  extends: .base_py_job
  stage: quality
  script:
    - echo "Linting NumPy-style docstrings in production Python code..."
    - uv run ruff check --select D src/{{ cookiecutter.project_slug }}

type-check:
  extends: .base_py_job
  stage: quality
  script:
    - echo "Type checking with MyPy..."
    - uv run ty check src/{{ cookiecutter.project_slug }}

check-todos:
  stage: test
  image: alpine:3.20
  rules:
    # run only on
    - if: $CI_COMMIT_TAG # tag pipelines
    - if: $CI_COMMIT_BRANCH =~ /^release\/.*$/ # release/* branches
  before_script:
    - apk add --no-cache ripgrep
  script:
    - sh scripts/check_todos.sh
  allow_failure: false
  artifacts:
    when: on_failure
    paths:
      - todo_hits.txt

publish:
  stage: publish
  image: ghcr.io/astral-sh/uv:$UV_VERSION-python$PYTHON_VERSION-$BASE_LAYER
  only:
    - tags
  before_script:
    - apt-get update && apt-get install -y git
  script:
    - VERSION=$(git describe --exact-match --tags)
    - uv tool run --from=toml-cli toml set --toml-path=pyproject.toml project.version $VERSION
    - uv build
    - uv publish dist/*.whl
